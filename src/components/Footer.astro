---
const currentYear = new Date().getFullYear();

const footerLinks = {
  categories: [
    { href: '/farming/', label: 'Farming', icon: '🌾' },
    { href: '/fishing/', label: 'Fishing', icon: '🎣' },
    { href: '/mining/', label: 'Mining', icon: '⛏️' },
    { href: '/social/', label: 'Social', icon: '💕' },
    { href: '/seasons/', label: 'Seasons', icon: '📅' },
    { href: '/quests/', label: 'Quests', icon: '📋' },
  ],
  popular: [
    { href: '/guides/getting-started', label: 'Getting Started', icon: '🚀' },
    { href: '/guides/crops-guide', label: 'Crop Guide', icon: '🌱' },
    { href: '/guides/fishing-guide', label: 'Fishing Guide', icon: '🐟' },
    { href: '/guides/money-making-guide', label: 'Money Making', icon: '💰' },
    { href: '/guides/year-one-guide', label: 'Year One', icon: '📅' },
  ],
  resources: [
    { href: '/guides/community-center', label: 'Community Center', icon: '🏠' },
    { href: '/guides/ginger-island-guide', label: 'Ginger Island', icon: '🏝️' },
    { href: '/guides/skills-guide', label: 'Skills Guide', icon: '⭐' },
    { href: '/items/', label: 'Items Database', icon: '🎒' },
    { href: '/locations/', label: 'Locations', icon: '🗺️' },
  ],
};
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Brand Column -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <span class="footer-logo-icon">🌿</span>
          <span class="footer-logo-text">Stardew Guide</span>
        </a>
        <p class="footer-desc">
          Your companion for Pelican Town! Master every aspect of Stardew Valley with our detailed guides.
        </p>
      </div>

      <!-- Categories Column -->
      <div class="footer-column">
        <h3 class="footer-column-title">Categories</h3>
        <ul class="footer-links">
          {footerLinks.categories.map((link) => (
            <li>
              <a href={link.href} class="footer-link">
                <span class="footer-link-icon">{link.icon}</span>
                <span class="footer-link-text">{link.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Popular Guides Column -->
      <div class="footer-column">
        <h3 class="footer-column-title">Popular</h3>
        <ul class="footer-links">
          {footerLinks.popular.map((link) => (
            <li>
              <a href={link.href} class="footer-link">
                <span class="footer-link-icon">{link.icon}</span>
                <span class="footer-link-text">{link.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Resources Column -->
      <div class="footer-column">
        <h3 class="footer-column-title">Resources</h3>
        <ul class="footer-links">
          {footerLinks.resources.map((link) => (
            <li>
              <a href={link.href} class="footer-link">
                <span class="footer-link-icon">{link.icon}</span>
                <span class="footer-link-text">{link.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Footer Bottom -->
    <div class="footer-bottom">
      <p class="copyright">
        © {currentYear} Stardew Guide. Made with 💚 for farmers!
      </p>
      <p class="disclaimer">
        Stardew Valley by <a href="https://www.stardewvalley.net/" target="_blank" rel="noopener noreferrer">ConcernedApe</a>. Fan-made project.
      </p>
    </div>
  </div>

  <!-- Back to Top Button -->
  <button
    class="back-to-top"
    id="back-to-top"
    aria-label="Back to top"
    title="Back to top"
  >
    <span class="back-top-icon">↑</span>
  </button>
</footer>

<style>
  .site-footer {
    position: relative;
    background: var(--color-bg-warm);
    border-top: 1px solid var(--color-border);
    padding: var(--space-16) 0 var(--space-8);
    margin-top: var(--space-16);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: var(--space-8);
    margin-bottom: var(--space-12);
  }

  /* Brand Column */
  .footer-brand {
    max-width: 280px;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    text-decoration: none;
    margin-bottom: var(--space-4);
    transition: opacity var(--transition-fast);
  }

  .footer-logo:hover {
    opacity: 0.8;
  }

  .footer-logo-icon {
    font-size: 1.5rem;
  }

  .footer-logo-text {
    font-family: var(--font-family);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-primary);
  }

  .footer-desc {
    font-family: var(--font-family);
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: 1.6;
    margin-bottom: 0;
  }

  /* Footer Columns */
  .footer-column {
    min-width: 0;
  }

  .footer-column-title {
    font-family: var(--font-family);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-4);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-links li {
    margin-bottom: var(--space-2);
  }

  .footer-link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text-secondary);
    font-family: var(--font-family);
    font-size: var(--text-sm);
    text-decoration: none;
    padding: var(--space-1) 0;
    transition: all var(--transition-fast);
  }

  .footer-link:hover {
    color: var(--color-primary);
    transform: translateX(4px);
  }

  .footer-link-icon {
    font-size: 1rem;
  }

  /* Footer Bottom */
  .footer-bottom {
    text-align: center;
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .copyright {
    font-family: var(--font-family);
    color: var(--color-text);
    font-size: var(--text-sm);
    margin-bottom: var(--space-2);
  }

  .disclaimer {
    font-family: var(--font-family);
    color: var(--color-text-muted);
    font-size: var(--text-xs);
    margin: 0;
  }

  .disclaimer a {
    color: var(--color-primary);
    text-decoration: underline;
  }

  .disclaimer a:hover {
    color: var(--color-primary-dark);
  }

  /* Back to Top Button */
  .back-to-top {
    position: fixed;
    bottom: var(--space-6);
    right: var(--space-6);
    width: 48px;
    height: 48px;
    background: var(--color-primary);
    border: none;
    border-radius: var(--radius-full);
    cursor: pointer;
    opacity: 0;
    visibility: hidden;
    transform: translateY(16px);
    transition: all var(--transition-base);
    z-index: 999;
    box-shadow: var(--shadow-md);
  }

  .back-to-top.visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .back-to-top:hover {
    background: var(--color-primary-dark);
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .back-top-icon {
    font-family: var(--font-family);
    font-size: var(--text-xl);
    color: var(--color-text-light);
    display: block;
    transition: transform var(--transition-fast);
  }

  .back-to-top:hover .back-top-icon {
    transform: translateY(-2px);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }

    .footer-brand {
      grid-column: 1 / -1;
      max-width: 100%;
      text-align: center;
    }

    .footer-logo {
      justify-content: center;
    }
  }

  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    .footer-column {
      text-align: center;
    }

    .footer-column-title {
      margin-bottom: var(--space-3);
    }

    .footer-link {
      justify-content: center;
    }

    .footer-link:hover {
      transform: none;
    }

    .back-to-top {
      width: 44px;
      height: 44px;
      bottom: var(--space-4);
      right: var(--space-4);
    }
  }
</style>

<script>
  const backToTopBtn = document.getElementById('back-to-top');

  if (backToTopBtn) {
    // Show/hide button based on scroll position
    const toggleBackToTop = () => {
      if (window.scrollY > 400) {
        backToTopBtn.classList.add('visible');
      } else {
        backToTopBtn.classList.remove('visible');
      }
    };

    window.addEventListener('scroll', toggleBackToTop, { passive: true });

    // Scroll to top when clicked
    backToTopBtn.addEventListener('click', () => {
      window.scrollTo({
        top: 0,
        behavior: 'smooth'
      });
    });
  }
</script>
