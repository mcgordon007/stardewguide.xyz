---
---

<div id="cookie-consent" class="cookie-consent" role="dialog" aria-label="Cookie Consent" aria-live="polite">
  <div class="cookie-consent-container">
    <div class="cookie-consent-content">
      <div class="cookie-consent-icon">🍪</div>
      <div class="cookie-consent-text">
        <p class="cookie-consent-title">We value your privacy</p>
        <p class="cookie-consent-description">
          We use cookies and similar technologies to enhance your browsing experience and serve personalized advertisements through Google AdSense. By clicking "Accept", you consent to our use of cookies.
          <a href="/privacy/" class="cookie-consent-link">Learn more in our Privacy Policy</a>.
        </p>
      </div>
    </div>
    <div class="cookie-consent-actions">
      <button id="cookie-accept" class="cookie-btn cookie-btn-primary" aria-label="Accept cookies">
        Accept
      </button>
      <a href="/privacy/" class="cookie-btn cookie-btn-secondary" aria-label="Learn more about cookies">
        Learn More
      </a>
    </div>
  </div>
</div>

<script>
  (function() {
    const COOKIE_CONSENT_KEY = 'stardew-guide-cookie-consent';
    const consentBanner = document.getElementById('cookie-consent');
    const acceptBtn = document.getElementById('cookie-accept');

    // Check if user has already made a choice
    function hasConsentChoice() {
      try {
        return localStorage.getItem(COOKIE_CONSENT_KEY) !== null;
      } catch (e) {
        return false;
      }
    }

    // Save consent choice
    function saveConsentChoice(accepted) {
      try {
        localStorage.setItem(COOKIE_CONSENT_KEY, accepted ? 'accepted' : 'declined');
      } catch (e) {
        // localStorage not available
      }
    }

    // Hide the consent banner
    function hideConsentBanner() {
      if (consentBanner) {
        consentBanner.classList.add('cookie-consent-hidden');
        // Remove from DOM after animation
        setTimeout(() => {
          consentBanner.style.display = 'none';
        }, 300);
      }
    }

    // Show the consent banner
    function showConsentBanner() {
      if (consentBanner) {
        consentBanner.style.display = 'block';
        // Trigger reflow for animation
        void consentBanner.offsetHeight;
        consentBanner.classList.remove('cookie-consent-hidden');
      }
    }

    // Initialize
    function init() {
      if (hasConsentChoice()) {
        // User has already made a choice, hide banner
        if (consentBanner) {
          consentBanner.style.display = 'none';
        }
      } else {
        // Show banner with slight delay for better UX
        setTimeout(() => {
          showConsentBanner();
        }, 1000);
      }
    }

    // Handle accept button click
    if (acceptBtn) {
      acceptBtn.addEventListener('click', function() {
        saveConsentChoice(true);
        hideConsentBanner();
      });
    }

    // Initialize on DOM ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

<style>
  .cookie-consent {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 9999;
    background: var(--color-card);
    border-top: 1px solid var(--color-border);
    box-shadow: var(--shadow-xl);
    padding: var(--space-4) 0;
    transform: translateY(0);
    opacity: 1;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .cookie-consent-hidden {
    transform: translateY(100%);
    opacity: 0;
  }

  .cookie-consent-container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-6);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
  }

  .cookie-consent-content {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    flex: 1;
  }

  .cookie-consent-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
    margin-top: var(--space-1);
  }

  .cookie-consent-text {
    flex: 1;
  }

  .cookie-consent-title {
    font-family: var(--font-family);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 var(--space-1) 0;
  }

  .cookie-consent-description {
    font-family: var(--font-family);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .cookie-consent-link {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color var(--transition-fast);
  }

  .cookie-consent-link:hover {
    color: var(--color-primary-dark);
  }

  .cookie-consent-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-shrink: 0;
  }

  .cookie-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2) var(--space-5);
    font-family: var(--font-family);
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: none;
    border: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all var(--transition-fast);
    white-space: nowrap;
  }

  .cookie-btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .cookie-btn-primary {
    background: var(--color-primary);
    color: var(--color-text-light);
  }

  .cookie-btn-primary:hover {
    background: var(--color-primary-dark);
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  .cookie-btn-secondary {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .cookie-btn-secondary:hover {
    background: var(--color-bg);
    border-color: var(--color-secondary);
    transform: translateY(-1px);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .cookie-consent-container {
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-4);
      padding: 0 var(--space-4);
    }

    .cookie-consent-content {
      align-items: flex-start;
    }

    .cookie-consent-actions {
      justify-content: flex-end;
    }
  }

  @media (max-width: 480px) {
    .cookie-consent-actions {
      flex-direction: column;
      width: 100%;
    }

    .cookie-btn {
      width: 100%;
    }
  }
</style>
