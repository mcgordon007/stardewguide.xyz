---
interface Props {
  href: string;
  title: string;
  description: string;
  icon: string;
  image?: string;
  color?: string;
  guideCount?: number;
}

const { 
  href, 
  title, 
  description, 
  icon, 
  image, 
  color = '#5A7D5A',
  guideCount 
} = Astro.props;
---

<a href={href} class="category-card" style={`--card-color: ${color}`}>
  <div class="card-background">
    {image && <img src={image} alt="" class="bg-image" loading="lazy" />}
    <div class="bg-overlay"></div>
  </div>
  
  <div class="card-content">
    <div class="icon-wrap">
      <span class="card-icon">{icon}</span>
    </div>
    
    <div class="text-content">
      <h3 class="card-title">{title}</h3>
      <p class="card-desc">{description}</p>
      
      {guideCount !== undefined && (
        <span class="guide-count">
          <span class="count-icon">📖</span>
          <span class="count-num">{guideCount}</span>
          <span class="count-label">{guideCount === 1 ? 'Guide' : 'Guides'}</span>
        </span>
      )}
    </div>
    
    <div class="card-arrow">
      <span>→</span>
    </div>
  </div>
</a>

<style>
  .category-card {
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: 200px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    color: var(--color-text-light);
    transition: all var(--transition-base);
    box-shadow: var(--shadow-md);
    --card-color: #5A7D5A;
  }

  .category-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  /* Background */
  .card-background {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 0;
  }

  .bg-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
    filter: brightness(0.5);
  }

  .category-card:hover .bg-image {
    transform: scale(1.05);
    filter: brightness(0.4);
  }

  .bg-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--card-color) 70%, transparent) 0%,
      color-mix(in srgb, var(--card-color) 85%, black) 100%
    );
    transition: background var(--transition-base);
  }

  .category-card:hover .bg-overlay {
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--card-color) 80%, transparent) 0%,
      color-mix(in srgb, var(--card-color) 90%, black) 100%
    );
  }

  /* Content */
  .card-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--space-6);
    height: 100%;
    gap: var(--space-3);
  }

  /* Icon */
  .icon-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    background: rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-lg);
    backdrop-filter: blur(4px);
    transition: all var(--transition-base);
  }

  .category-card:hover .icon-wrap {
    background: rgba(255, 255, 255, 0.3);
    transform: scale(1.1);
  }

  .card-icon {
    font-size: 2rem;
    transition: transform var(--transition-base);
  }

  .category-card:hover .card-icon {
    transform: scale(1.15);
  }

  /* Text Content */
  .text-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
  }

  .card-title {
    font-family: var(--font-family);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--color-text-light);
    margin: 0;
  }

  .card-desc {
    font-family: var(--font-family);
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.5;
    margin: 0;
    max-width: 180px;
  }

  .guide-count {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    background: rgba(255, 255, 255, 0.2);
    padding: var(--space-1) var(--space-2);
    font-family: var(--font-family);
    font-size: var(--text-xs);
    font-weight: 500;
    color: rgba(255, 255, 255, 0.9);
    border-radius: var(--radius-sm);
    margin-top: var(--space-2);
    backdrop-filter: blur(4px);
  }

  .count-icon {
    font-size: 0.875rem;
  }

  /* Arrow */
  .card-arrow {
    position: absolute;
    bottom: var(--space-4);
    right: var(--space-4);
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-full);
    opacity: 0;
    transform: translateX(-8px);
    transition: all var(--transition-base);
    backdrop-filter: blur(4px);
  }

  .category-card:hover .card-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .card-arrow span {
    font-size: var(--text-base);
    color: var(--color-text-light);
    transition: transform var(--transition-fast);
  }

  .category-card:hover .card-arrow span {
    transform: translateX(2px);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .category-card {
      min-height: 160px;
    }

    .card-content {
      padding: var(--space-4);
      gap: var(--space-2);
    }

    .icon-wrap {
      width: 56px;
      height: 56px;
    }

    .card-icon {
      font-size: 1.75rem;
    }

    .card-title {
      font-size: var(--text-lg);
    }

    .card-desc {
      font-size: var(--text-xs);
    }

    .card-arrow {
      opacity: 1;
      transform: none;
      width: 28px;
      height: 28px;
    }
  }

  @media (max-width: 480px) {
    .category-card {
      min-height: 140px;
    }

    .icon-wrap {
      width: 48px;
      height: 48px;
    }

    .card-icon {
      font-size: 1.5rem;
    }

    .guide-count {
      display: none;
    }
  }
</style>
