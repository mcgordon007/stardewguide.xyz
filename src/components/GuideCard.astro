---
interface Props {
  title: string;
  description: string;
  slug: string;
  category: string;
  season?: string;
  difficulty?: string;
  featured?: boolean;
  image?: string;
}

const { title, description, slug, category, season, difficulty, featured = false, image } = Astro.props;

const categoryIcons: Record<string, string> = {
  basics: "📖",
  farming: "🌾",
  fishing: "🎣",
  mining: "⛏️",
  foraging: "🍄",
  combat: "⚔️",
  social: "💕",
  seasons: "📅",
  skills: "⭐",
  quests: "📋",
  items: "🎒",
  locations: "🗺️",
};

const categoryLabels: Record<string, string> = {
  basics: "Basics",
  farming: "Farming",
  fishing: "Fishing",
  mining: "Mining",
  foraging: "Foraging",
  combat: "Combat",
  social: "Social",
  seasons: "Seasons",
  skills: "Skills",
  quests: "Quests",
  items: "Items",
  locations: "Locations",
};

const seasonLabels: Record<string, string> = {
  spring: "Spring",
  summer: "Summer",
  fall: "Fall",
  winter: "Winter",
  all: "All Seasons",
};

const seasonBadgeClasses: Record<string, string> = {
  spring: "badge-spring",
  summer: "badge-summer",
  fall: "badge-fall",
  winter: "badge-winter",
  all: "badge-spring",
};

const difficultyLabels: Record<string, string> = {
  beginner: "Beginner",
  intermediate: "Intermediate",
  advanced: "Advanced",
};

const difficultyBadgeClasses: Record<string, string> = {
  beginner: "badge-beginner",
  intermediate: "badge-intermediate",
  advanced: "badge-advanced",
};
---

<a href={`/guides/${slug}`} class:list={["guide-card", { featured }]}>
  {featured && (
    <div class="featured-badge">
      <span class="featured-icon">⭐</span>
      <span class="featured-text">Featured</span>
    </div>
  )}
  
  <div class="card-media">
    {image ? (
      <div class="card-image-wrap">
        <img src={image} alt={title} loading="lazy" class="card-image" />
      </div>
    ) : (
      <div class="card-icon-wrap">
        <span class="card-icon">{categoryIcons[category] || "📖"}</span>
      </div>
    )}
    
    <div class="category-tag">
      <span class="category-tag-icon">{categoryIcons[category] || "📖"}</span>
      <span class="category-tag-text">{categoryLabels[category] || category}</span>
    </div>
  </div>
  
  <div class="card-content">
    <h3 class="card-title">{title}</h3>
    <p class="card-desc">{description}</p>
    
    <div class="card-meta">
      {season && (
        <span class:list={["badge", seasonBadgeClasses[season] || seasonBadgeClasses.all]}>
          <span class="meta-icon">🌿</span>
          <span>{seasonLabels[season] || season}</span>
        </span>
      )}
      
      {difficulty && (
        <span class:list={["badge", difficultyBadgeClasses[difficulty]]}>
          <span class="meta-icon">
            {difficulty === 'beginner' && '🟢'}
            {difficulty === 'intermediate' && '🟡'}
            {difficulty === 'advanced' && '🔴'}
          </span>
          <span>{difficultyLabels[difficulty] || difficulty}</span>
        </span>
      )}
    </div>
  </div>
  
  <div class="card-footer">
    <span class="read-text">Read Guide</span>
    <span class="read-arrow">→</span>
  </div>
</a>

<style>
  .guide-card {
    display: flex;
    flex-direction: column;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    color: var(--color-text);
    transition: all var(--transition-base);
    box-shadow: var(--shadow-md);
    position: relative;
    height: 100%;
  }

  .guide-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-primary-light);
  }

  .guide-card.featured {
    border-color: var(--color-accent);
  }

  .guide-card.featured:hover {
    border-color: var(--color-accent-light);
  }

  /* Featured Badge */
  .featured-badge {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    display: flex;
    align-items: center;
    gap: var(--space-1);
    background: var(--color-accent);
    color: var(--color-text);
    padding: var(--space-1) var(--space-2);
    font-family: var(--font-family);
    font-size: var(--text-xs);
    font-weight: 600;
    border-radius: var(--radius-sm);
    z-index: 10;
  }

  .featured-icon {
    font-size: 0.875rem;
  }

  /* Card Media */
  .card-media {
    position: relative;
    height: 160px;
    overflow: hidden;
    background: var(--color-bg-warm);
  }

  .card-image-wrap {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .guide-card:hover .card-image {
    transform: scale(1.05);
  }

  .card-icon-wrap {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--color-primary-light) 0%, var(--color-primary) 100%);
  }

  .card-icon {
    font-size: 3rem;
    transition: transform var(--transition-base);
  }

  .guide-card:hover .card-icon {
    transform: scale(1.1);
  }

  /* Category Tag */
  .category-tag {
    position: absolute;
    bottom: var(--space-2);
    left: var(--space-2);
    display: flex;
    align-items: center;
    gap: var(--space-1);
    background: var(--color-card);
    border: 1px solid var(--color-border);
    padding: var(--space-1) var(--space-2);
    font-family: var(--font-family);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-sm);
  }

  .category-tag-icon {
    font-size: 0.875rem;
  }

  /* Card Content */
  .card-content {
    padding: var(--space-4);
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .card-title {
    font-family: var(--font-family);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-2);
    line-height: 1.4;
    transition: color var(--transition-fast);
  }

  .guide-card:hover .card-title {
    color: var(--color-primary);
  }

  .card-desc {
    font-family: var(--font-family);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-3);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  /* Card Meta */
  .card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: auto;
  }

  .meta-icon {
    font-size: 0.75rem;
  }

  /* Card Footer */
  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
    transition: all var(--transition-fast);
  }

  .guide-card:hover .card-footer {
    background: var(--color-primary);
  }

  .read-text {
    font-family: var(--font-family);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-primary);
    transition: color var(--transition-fast);
  }

  .guide-card:hover .read-text {
    color: var(--color-text-light);
  }

  .read-arrow {
    font-size: var(--text-base);
    color: var(--color-primary);
    transition: all var(--transition-fast);
    transform: translateX(-4px);
    opacity: 0;
  }

  .guide-card:hover .read-arrow {
    color: var(--color-text-light);
    transform: translateX(0);
    opacity: 1;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .card-media {
      height: 140px;
    }

    .card-icon {
      font-size: 2.5rem;
    }

    .card-content {
      padding: var(--space-3);
    }

    .card-title {
      font-size: var(--text-base);
    }

    .featured-badge {
      padding: var(--space-1) var(--space-2);
      font-size: 10px;
    }
  }
</style>
