---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" description="The page you are looking for could not be found. Return to our Stardew Valley guides homepage or search for what you need." noindex={true}>
  <!-- ErrorPage Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "404 - Page Not Found",
    "description": "The requested page could not be found on Stardew Valley Guide.",
    "url": "https://stardewguide.xyz/404/"
  })} />

  <article class="error-page container">
    <div class="error-content">
      <!-- Error Icon -->
      <div class="error-icon-wrapper">
        <span class="error-icon">🌾</span>
        <span class="error-icon-overlay">❌</span>
      </div>

      <!-- Error Message -->
      <h1 class="error-title">404 - Page Not Found</h1>
      <p class="error-message">
        Oops! It looks like this crop didn't grow. The page you are looking for has either been moved, deleted, or never existed in our farm.
      </p>

      <!-- Helpful Suggestions -->
      <div class="suggestions-box">
        <h2>What You Can Do:</h2>
        <ul class="suggestions-list">
          <li>
            <span class="suggestion-icon">🏠</span>
            <a href="/">Return to Homepage</a> - Start fresh from our main page
          </li>
          <li>
            <span class="suggestion-icon">📖</span>
            <a href="/guides/">Browse All Guides</a> - Find the guide you need
          </li>
          <li>
            <span class="suggestion-icon">🔍</span>
            <a href="/guides/?q=">Search Guides</a> - Look for specific content
          </li>
          <li>
            <span class="suggestion-icon">📧</span>
            <a href="/about/">Contact Us</a> - Report a broken link
          </li>
        </ul>
      </div>

      <!-- Quick Links -->
      <div class="quick-links">
        <h3>Popular Guides:</h3>
        <div class="quick-links-grid">
          <a href="/guides/getting-started" class="quick-link">
            <span class="quick-icon">🚀</span>
            <span>Getting Started</span>
          </a>
          <a href="/guides/fishing-guide" class="quick-link">
            <span class="quick-icon">🎣</span>
            <span>Fishing Guide</span>
          </a>
          <a href="/guides/crops-guide" class="quick-link">
            <span class="quick-icon">🌾</span>
            <span>Crops Guide</span>
          </a>
          <a href="/guides/community-center" class="quick-link">
            <span class="quick-icon">🏛️</span>
            <span>Community Center</span>
          </a>
          <a href="/guides/skills-guide" class="quick-link">
            <span class="quick-icon">⭐</span>
            <span>Skills Guide</span>
          </a>
          <a href="/guides/money-making-guide" class="quick-link">
            <span class="quick-icon">💰</span>
            <span>Money Making</span>
          </a>
        </div>
      </div>

      <!-- Search Box -->
      <div class="search-suggestion">
        <p>Looking for something specific? Try browsing by category:</p>
        <div class="category-links">
          <a href="/categories/basics" class="cat-link">🚀 Basics</a>
          <a href="/categories/farming" class="cat-link">🌾 Farming</a>
          <a href="/categories/fishing" class="cat-link">🎣 Fishing</a>
          <a href="/categories/mining" class="cat-link">⛏️ Mining</a>
          <a href="/categories/social" class="cat-link">💕 Social</a>
          <a href="/categories/seasons" class="cat-link">📅 Seasons</a>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .error-page {
    padding-top: var(--space-8);
    padding-bottom: var(--space-16);
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .error-content {
    max-width: 700px;
    text-align: center;
  }

  /* Error Icon */
  .error-icon-wrapper {
    position: relative;
    display: inline-block;
    margin-bottom: var(--space-6);
  }

  .error-icon {
    font-size: 6rem;
    opacity: 0.6;
  }

  .error-icon-overlay {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 3rem;
  }

  /* Error Title */
  .error-title {
    font-family: var(--font-family);
    font-size: var(--text-3xl);
    color: var(--color-primary);
    margin-bottom: var(--space-4);
  }

  .error-message {
    font-family: var(--font-family);
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
    line-height: 1.6;
  }

  /* Suggestions Box */
  .suggestions-box {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    margin-bottom: var(--space-6);
    box-shadow: var(--shadow-md);
    position: relative;
  }

  .suggestions-box h2 {
    font-family: var(--font-family);
    font-size: var(--text-xl);
    color: var(--color-primary);
    margin-bottom: var(--space-4);
  }

  .suggestions-list {
    list-style: none;
    padding: 0;
    margin: 0;
    text-align: left;
  }

  .suggestions-list li {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2);
    font-family: var(--font-family);
    font-size: var(--text-base);
    margin-bottom: var(--space-2);
  }

  .suggestion-icon {
    font-size: 1.25rem;
  }

  .suggestions-list a {
    color: var(--color-primary);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: all var(--transition-fast);
  }

  .suggestions-list a:hover {
    border-bottom-color: var(--color-primary);
  }

  /* Quick Links */
  .quick-links {
    margin-bottom: var(--space-6);
  }

  .quick-links h3 {
    font-family: var(--font-family);
    font-size: var(--text-lg);
    color: var(--color-secondary);
    margin-bottom: var(--space-3);
  }

  .quick-links-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }

  .quick-link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    background: var(--color-card);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: var(--font-family);
    font-size: var(--text-sm);
    text-decoration: none;
    box-shadow: var(--shadow-sm);
    transition: all var(--transition-fast);
  }

  .quick-link:hover {
    box-shadow: var(--shadow-md);
  }

  .quick-icon {
    font-size: 1rem;
  }

  /* Search Suggestion */
  .search-suggestion {
    background: var(--color-card);
    color: var(--color-text);
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }

  .search-suggestion p {
    font-family: var(--font-family);
    font-size: var(--text-base);
    margin-bottom: var(--space-3);
  }

  .category-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    justify-content: center;
  }

  .cat-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-1) var(--space-2);
    background: var(--color-card);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: var(--font-family);
    font-size: var(--text-sm);
    text-decoration: none;
    box-shadow: var(--shadow-sm);
    transition: all var(--transition-fast);
  }

  .cat-link:hover {
    box-shadow: var(--shadow-md);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .error-page {
      padding-top: var(--space-4);
      padding-bottom: var(--space-8);
    }

    .error-icon {
      font-size: 4rem;
    }

    .error-icon-overlay {
      font-size: 2rem;
    }

    .error-title {
      font-size: var(--text-2xl);
    }

    .suggestions-box {
      padding: var(--space-4);
    }

    .quick-links-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .quick-links-grid {
      grid-template-columns: 1fr;
    }

    .suggestions-list li {
      flex-wrap: wrap;
    }
  }
</style>
