        <a href="/">Home</a>
        <span>/</span>
        <span>Terms of Service</span>
      </nav>

      <header class="page-header">
        <h1 class="page-title">Terms of Service</h1>
        <p class="page-subtitle">Last updated: May 31, 2026</p>
      </header>

      <div class="content-wrapper">
        <section class="content-section">
