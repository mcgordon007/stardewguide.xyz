---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  category?: string;
  season?: string;
  difficulty?: string;
  date?: Date;
  updated?: Date;
  tags?: string[];
  image?: string;
  slug?: string;
  faqItems?: Array<{ question: string; answer: string }>;
  howToSteps?: Array<{ name: string; text: string; image?: string }>;
  isTutorial?: boolean;
}

const { title, description, category, season, difficulty, date, updated, tags, image, slug, faqItems, howToSteps, isTutorial } = Astro.props;

const categoryIcons: Record<string, string> = {
  basics: '🚀',
  farming: '🌾',
  fishing: '🎣',
  mining: '⛏️',
  foraging: '🍄',
  combat: '⚔️',
  social: '💕',
  seasons: '📅',
  skills: '⭐',
  quests: '📋',
};

const categoryLabels: Record<string, string> = {
  basics: 'Basics',
  farming: 'Farming',
  fishing: 'Fishing',
  mining: 'Mining',
  foraging: 'Foraging',
  combat: 'Combat',
  social: 'Social',
  seasons: 'Seasons',
  skills: 'Skills',
  quests: 'Quests',
};

const seasonIcons: Record<string, string> = {
  spring: '🌱',
  summer: '☀️',
  fall: '🍂',
  winter: '❄️',
  all: '📅',
};

const seasonLabels: Record<string, string> = {
  spring: 'Spring',
  summer: 'Summer',
  fall: 'Fall',
  winter: 'Winter',
  all: 'All Seasons',
};

const seasonColors: Record<string, string> = {
  spring: 'var(--color-spring)',
  summer: 'var(--color-summer)',
  fall: 'var(--color-fall)',
  winter: 'var(--color-winter)',
  all: 'var(--color-primary)',
};

const difficultyIcons: Record<string, string> = {
  beginner: '🟢',
  intermediate: '🟡',
  advanced: '🔴',
};

const difficultyLabels: Record<string, string> = {
  beginner: 'Beginner',
  intermediate: 'Intermediate',
  advanced: 'Advanced',
};

// Build breadcrumb items based on category
const breadcrumbItems = [
  { "@type": "ListItem", position: 1, name: "Home", item: "https://stardewguide.xyz/" },
  { "@type": "ListItem", position: 2, name: "Guides", item: "https://stardewguide.xyz/guides/" },
];

if (category) {
  breadcrumbItems.push({
    "@type": "ListItem",
    position: 3,
    name: categoryLabels[category] || category,
    item: `https://stardewguide.xyz/categories/${category}/`
  });
  breadcrumbItems.push({
    "@type": "ListItem",
    position: 4,
    name: title,
    item: `https://stardewguide.xyz/guides/${slug}/`
  });
} else {
  breadcrumbItems.push({
    "@type": "ListItem",
    position: 3,
    name: title,
    item: `https://stardewguide.xyz/guides/${slug}/`
  });
}
---

<BaseLayout title={title} description={description}>
  <!-- JSON-LD Article Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description || "",
    "url": `https://stardewguide.xyz/guides/${slug}/`,
    "datePublished": date ? date.toISOString().split('T')[0] : new Date().toISOString().split('T')[0],
    "dateModified": updated ? updated.toISOString().split('T')[0] : (date ? date.toISOString().split('T')[0] : new Date().toISOString().split('T')[0]),
    "author": {
      "@type": "Organization",
      "name": "Stardew Valley Guide"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Stardew Valley Guide",
      "logo": {
        "@type": "ImageObject",
        "url": "https://stardewguide.xyz/favicon.svg"
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": `https://stardewguide.xyz/guides/${slug}/`
    },
    "image": image ? `https://stardewguide.xyz${image}` : "https://stardewguide.xyz/images/farming-banner.jpg"
  })} />

  <!-- JSON-LD BreadcrumbList Schema (Enhanced with category support) -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": breadcrumbItems
  })} />

  <!-- JSON-LD FAQPage Schema (if faqItems provided) -->
  {faqItems && faqItems.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqItems.map(item => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.answer
        }
      }))
    })} />
  )}

  <!-- JSON-LD HowTo Schema (for tutorial guides) -->
  {isTutorial && howToSteps && howToSteps.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "HowTo",
      "name": title,
      "description": description || "",
      "step": howToSteps.map((step, index) => ({
        "@type": "HowToStep",
        "position": index + 1,
        "name": step.name,
        "text": step.text,
        "image": step.image ? `https://stardewguide.xyz${step.image}` : undefined
      })),
      "totalTime": "PT30M",
      "estimatedCost": {
        "@type": "MonetaryAmount",
        "currency": "USD",
        "value": "0"
      },
      "tool": [
        {
          "@type": "HowToTool",
          "name": "Stardew Valley Game"
        }
      ]
    })} />
  )}

  <article class="guide-article container">
    <!-- Breadcrumb -->
    <div class="guide-breadcrumb">
      <a href="/" class="breadcrumb-link">
        <span class="breadcrumb-icon">🏠</span>
        <span>Home</span>
      </a>
      <span class="breadcrumb-sep">/</span>
      <a href="/guides/" class="breadcrumb-link">
        <span class="breadcrumb-icon">📖</span>
        <span>Guides</span>
      </a>
      {category && (
        <>
          <span class="breadcrumb-sep">/</span>
          <a href={`/categories/${category}`} class="breadcrumb-link">
            <span class="breadcrumb-icon">{categoryIcons[category] || '🚀'}</span>
            <span>{categoryLabels[category] || category}</span>
          </a>
        </>
      )}
      <span class="breadcrumb-sep">/</span>
      <span class="breadcrumb-current">{title}</span>
    </div>

    <!-- Title Banner -->
    <div class="guide-title-banner">
      <h1 class="guide-title">{title}</h1>
      {description && <p class="guide-desc">{description}</p>}
      
      <!-- Meta Tags -->
      <div class="guide-meta">
        {category && (
          <a href={`/categories/${category}`} class="guide-badge guide-cat-badge">
            <span class="meta-badge-icon">{categoryIcons[category] || '🚀'}</span>
            <span class="meta-badge-text">{categoryLabels[category] || category}</span>
          </a>
        )}
        {season && (
          <span class="guide-badge guide-season-badge" style={`--badge-color: ${seasonColors[season]}`}>
            <span class="meta-badge-icon">{seasonIcons[season] || '📅'}</span>
            <span class="meta-badge-text">{seasonLabels[season] || season}</span>
          </span>
        )}
        {difficulty && (
          <span class:list={["guide-badge", "guide-diff-badge", `diff-${difficulty}`]}>
            <span class="meta-badge-icon">{difficultyIcons[difficulty] || '🟢'}</span>
            <span class="meta-badge-text">{difficultyLabels[difficulty] || difficulty}</span>
          </span>
        )}
        {date && (
          <span class="guide-meta-date">
            <span class="meta-date-icon">📅</span>
            Published: {date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
          </span>
        )}
        {updated && (
          <span class="guide-meta-date">
            <span class="meta-date-icon">🔄</span>
            Updated: {updated.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
          </span>
        )}
      </div>

      <!-- Tags -->
      {tags && tags.length > 0 && (
        <div class="guide-tags">
          {tags.map(tag => (
            <span class="tag">
              <span class="tag-hash">#</span>
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>

    <!-- Banner Image -->
    {image && (
      <div class="guide-banner">
        <img src={image} alt={title} />
      </div>
    )}

    <!-- Content Area with TOC -->
    <div class="guide-layout">
      <aside class="guide-sidebar">
        <nav class="toc-nav" aria-label="Table of contents">
          <h3 class="toc-title">Contents</h3>
          <ul class="toc-list" id="toc-list"></ul>
        </nav>
      </aside>
      <div class="guide-content">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>

<script>
  // Auto-generate TOC from headings
  (function() {
    const content = document.querySelector('.guide-content');
    const tocList = document.getElementById('toc-list');
    if (!content || !tocList) return;

    const headings = content.querySelectorAll('h2, h3');
    if (headings.length < 2) {
      const sidebar = document.querySelector('.guide-sidebar');
      if (sidebar) sidebar.style.display = 'none';
      return;
    }

    headings.forEach((heading, i) => {
      const id = heading.id || 'section-' + i;
      heading.id = id;
      const li = document.createElement('li');
      li.className = 'toc-item toc-' + heading.tagName.toLowerCase();
      const a = document.createElement('a');
      a.href = '#' + id;
      a.textContent = heading.textContent;
      a.addEventListener('click', (e) => {
        e.preventDefault();
        heading.scrollIntoView({ behavior: 'smooth', block: 'start' });
        history.pushState(null, '', '#' + id);
      });
      li.appendChild(a);
      tocList.appendChild(li);
    });

    // Highlight active section on scroll
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          tocList.querySelectorAll('a').forEach(a => a.classList.remove('toc-active'));
          const active = tocList.querySelector('a[href="#' + id + '"]');
          if (active) active.classList.add('toc-active');
        }
      });
    }, { rootMargin: '-80px 0px -60% 0px', threshold: 0 });

    headings.forEach(h => observer.observe(h));
  })();
</script>

<style>
  .guide-article {
    padding-top: var(--space-8);
    padding-bottom: var(--space-16);
  }

  .guide-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 2rem;
    align-items: start;
  }

  .guide-sidebar {
    position: sticky;
    top: calc(var(--header-height) + 2rem);
    max-height: calc(100vh - var(--header-height) - 4rem);
    overflow-y: auto;
  }

  .toc-nav {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1rem;
  }

  .toc-title {
    font-family: var(--font-pixel);
    font-size: 0.9rem;
    color: var(--color-accent);
    margin: 0 0 0.75rem 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 0.85rem;
  }

  .toc-item {
    margin: 0;
    padding: 0;
  }

  .toc-item a {
    display: block;
    padding: 0.35rem 0.5rem;
    color: var(--color-text-muted);
    text-decoration: none;
    border-radius: var(--radius-sm);
    transition: all 0.15s;
    border-left: 2px solid transparent;
  }

  .toc-item a:hover {
    color: var(--color-primary);
    background: rgba(90, 125, 90, 0.08);
  }

  .toc-item a.toc-active {
    color: var(--color-primary);
    border-left-color: var(--color-primary);
    background: rgba(90, 125, 90, 0.1);
    font-weight: 600;
  }

  .toc-h3 {
    padding-left: 1rem;
    font-size: 0.8rem;
  }

  @media (max-width: 900px) {
    .guide-layout {
      grid-template-columns: 1fr;
    }
    .guide-sidebar {
      display: none;
    }
  }

  /* Breadcrumb */
  .guide-breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) 0;
    margin-bottom: var(--space-4);
    font-family: var(--font-family);
    font-size: var(--text-sm);
    letter-spacing: normal;
    flex-wrap: wrap;
  }

  .breadcrumb-link {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    color: var(--color-primary);
    padding: var(--space-1) var(--space-2);
    border: 1px solid transparent;
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
  }

  .breadcrumb-link:hover {
    border-color: var(--color-primary);
    background: var(--color-primary-light);
    color: var(--color-primary-dark);
  }

  .breadcrumb-icon {
    font-size: 1rem;
  }

  .breadcrumb-sep {
    color: var(--color-text-muted);
  }

  .breadcrumb-current {
    color: var(--color-text);
    padding: var(--space-1) var(--space-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
  }

  /* Title Banner */
  .guide-title-banner {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    margin-bottom: var(--space-6);
    box-shadow: var(--shadow-md);
    position: relative;
  }

  .guide-title {
    font-family: var(--font-family);
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: var(--space-2);
    letter-spacing: normal;
    line-height: 1.3;
  }

  .guide-desc {
    font-family: var(--font-family);
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4);
    letter-spacing: normal;
    line-height: 1.6;
  }

  /* Meta Tags */
  .guide-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
    margin-bottom: var(--space-3);
  }

  .guide-badge {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-1) var(--space-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-family: var(--font-family);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: normal;
    transition: all var(--transition-fast);
  }

  .guide-badge:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-sm);
  }

  .guide-cat-badge {
    background: var(--color-primary-light);
    color: var(--color-primary-dark);
    border-color: var(--color-primary);
  }

  .guide-season-badge {
    background: var(--badge-color, var(--color-primary));
    color: var(--color-text-light);
    border-color: transparent;
  }

  .guide-diff-badge.diff-beginner {
    background: var(--color-beginner);
    color: var(--color-text-light);
    border-color: transparent;
  }

  .guide-diff-badge.diff-intermediate {
    background: var(--color-intermediate);
    color: var(--color-text);
    border-color: var(--color-accent);
  }

  .guide-diff-badge.diff-advanced {
    background: var(--color-advanced);
    color: var(--color-text-light);
    border-color: transparent;
  }

  .meta-badge-icon {
    font-size: 1rem;
  }

  .guide-meta-date {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    font-family: var(--font-family);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    letter-spacing: normal;
  }

  .meta-date-icon {
    font-size: 1rem;
  }

  /* Tags */
  .guide-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-3);
  }

  .tag {
    display: flex;
    align-items: center;
    font-family: var(--font-family);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-1) var(--space-2);
    transition: all var(--transition-fast);
  }

  .tag:hover {
    border-color: var(--color-primary-light);
    background: var(--color-primary-light);
  }

  .tag-hash {
    color: var(--color-accent);
    margin-right: 2px;
  }

  /* Banner Image */
  .guide-banner {
    width: 100%;
    max-width: 800px;
    margin: 0 auto var(--space-6);
    position: relative;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    overflow: hidden;
  }

  .guide-banner img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Content Area */
  .guide-content {
    max-width: 800px;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    box-shadow: var(--shadow-md);
    position: relative;
  }

  /* Guide Content Typography */
  .guide-content :global(h2) {
    font-family: var(--font-family);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-primary);
    margin: var(--space-6) 0 var(--space-3);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-border);
    letter-spacing: normal;
    line-height: 1.4;
  }

  .guide-content :global(h3) {
    font-family: var(--font-family);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--color-accent);
    margin: var(--space-5) 0 var(--space-2);
    letter-spacing: normal;
    line-height: 1.4;
  }

  .guide-content :global(h4) {
    font-family: var(--font-family);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-primary-light);
    margin: var(--space-4) 0 var(--space-2);
    letter-spacing: normal;
    line-height: 1.4;
  }

  .guide-content :global(p) {
    margin-bottom: var(--space-3);
    font-family: var(--font-family);
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--color-text);
  }

  .guide-content :global(ul),
  .guide-content :global(ol) {
    margin: var(--space-3) 0 var(--space-3) var(--space-6);
    font-family: var(--font-family);
  }

  .guide-content :global(li) {
    margin-bottom: var(--space-2);
    font-family: var(--font-family);
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--color-text);
  }

  .guide-content :global(strong) {
    color: var(--color-accent);
    font-weight: 600;
  }

  .guide-content :global(code) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-1) var(--space-2);
    font-family: var(--font-family);
    font-size: var(--text-sm);
  }

  .guide-content :global(blockquote) {
    border-left: 4px solid var(--color-primary);
    padding: var(--space-4);
    margin: var(--space-4) 0;
    background: var(--color-surface);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    font-family: var(--font-family);
    font-size: var(--text-base);
    color: var(--color-text-secondary);
  }

  .guide-content :global(hr) {
    border: none;
    height: 1px;
    background: var(--color-border);
    margin: var(--space-6) 0;
  }

  .guide-content :global(img) {
    max-width: 100%;
    height: auto;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    margin: var(--space-4) 0;
  }

  .guide-content :global(table) {
    width: 100%;
    margin: var(--space-4) 0;
    font-family: var(--font-family);
    font-size: var(--text-sm);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    background: var(--color-card);
  }

  .guide-content :global(th) {
    background: var(--color-primary);
    color: var(--color-text-light);
    padding: var(--space-3);
    text-align: left;
    font-family: var(--font-family);
    font-weight: 600;
    letter-spacing: normal;
    border-bottom: 1px solid var(--color-border);
  }

  .guide-content :global(td) {
    padding: var(--space-3);
    border-bottom: 1px solid var(--color-border-light);
  }

  .guide-content :global(tr:last-child td) {
    border-bottom: none;
  }

  .guide-content :global(tr:hover td) {
    background: var(--color-surface);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .guide-article {
      padding-top: var(--space-4);
      padding-bottom: var(--space-8);
    }

    .guide-title-banner {
      padding: var(--space-4);
    }

    .guide-title {
      font-size: var(--text-2xl);
    }

    .guide-content {
      padding: var(--space-4);
    }

    .guide-content :global(h2) {
      font-size: var(--text-xl);
    }

    .guide-content :global(h3) {
      font-size: var(--text-lg);
    }
  }
</style>
